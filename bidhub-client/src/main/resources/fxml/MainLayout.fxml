<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bidhub.client.controller.MainLayoutController"
            stylesheets="@/css/styles.css"
            styleClass="root"
            fx:id="mainPane">

    <left>
        <VBox spacing="5" style="-fx-background-color: #1A1F2E; -fx-padding: 18 12; -fx-min-width: 215; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 10, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 14 4;">
                <Label text="⚡" style="-fx-text-fill: #4F46E5; -fx-font-size: 20px;"/>
                <Label text="BidHub" style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: 900;"/>
            </HBox>

            <Label text="KHÁM PHÁ" style="-fx-text-fill: #475569; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 6 0 3 5;"/>

            <Button fx:id="btnAuctionList" text="🏛  Phiên Đấu Giá"
                    maxWidth="Infinity" styleClass="button, btn-primary" />

            <Button fx:id="btnItemCatalog" text="📦  Kho Sản Phẩm"
                    maxWidth="Infinity" onAction="#handleItemCatalog"
                    styleClass="button, btn-primary" />

            <Button fx:id="btnNotifications" text="🔔  Thông Báo"
                    maxWidth="Infinity" onAction="#handleNotifications"
                    styleClass="button, btn-primary" />

            <Label text="NGƯỜI BÁN" style="-fx-text-fill: #475569; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 8 0 3 5;"/>

            <Button fx:id="btnCreateItem"    text="➕  Thêm Sản Phẩm"
                    maxWidth="Infinity" styleClass="button, btn-primary" />
            <Button fx:id="btnCreateAuction" text="📊  Tạo Phiên Mới"
                    maxWidth="Infinity" styleClass="button, btn-primary" />
            <Button fx:id="btnSellerDashboard" text="🗂  Sản Phẩm Của Tôi"
                    maxWidth="Infinity" onAction="#handleSellerDashboard"
                    styleClass="button, btn-primary" visible="false" managed="false" />

            <Button fx:id="adminBtn" text="🛡  Quản Trị Viên"
                    maxWidth="Infinity" styleClass="button, btn-warning"
                    visible="false" managed="false" onAction="#handleAdminPanel" />

            <Region VBox.vgrow="ALWAYS" />

            <Button fx:id="btnAccount"       text="👤  Tài Khoản"
                    maxWidth="Infinity" styleClass="button, btn-primary" />
            <Button fx:id="btnLogout"        text="🚪  Đăng Xuất"
                    maxWidth="Infinity" style="-fx-background-color: transparent; -fx-border-color: #EF4444; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-text-fill: #EF4444; -fx-cursor: hand; -fx-padding: 10 20; -fx-font-weight: bold;" />
        </VBox>
    </left>
    <center>
    </center>
</BorderPane>
