<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bidhub.client.controller.MainLayoutController"
            stylesheets="@/css/styles.css"
            styleClass="root"
            fx:id="mainPane">

    <left>
        <VBox spacing="8" style="-fx-background-color: #1A1F2E; -fx-padding: 20 15; -fx-min-width: 220; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 10, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 15 0;">
                <Label text="⚡" style="-fx-text-fill: #4F46E5; -fx-font-size: 22px;"/>
                <Label text="BidHub" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 900;"/>
            </HBox>

            <VBox style="-fx-background-color: #2E364F; -fx-padding: 8 12; -fx-background-radius: 6; -fx-margin: 0 0 10 0;">
                <Label fx:id="lblSidebarUser" text="👤 Khách" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <Label fx:id="lblSidebarRole" text="Vai trò: Bidder" style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;"/>
            </VBox>

            <Label text="KHÁM PHÁ" style="-fx-text-fill: #475569; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 8 0 4 5;"/>

            <Button fx:id="btnAuctionList" text="🏛  Phiên Đấu Giá"
                    maxWidth="Infinity" styleClass="button, btn-primary" />

            <Button fx:id="btnItemCatalog" text="📦  Kho Sản Phẩm"
                    maxWidth="Infinity" onAction="#handleItemCatalog"
                    styleClass="button, btn-primary" />

            <Button fx:id="btnNotifications" text="🔔  Thông Báo"
                    maxWidth="Infinity" onAction="#handleNotifications"
                    styleClass="button, btn-primary" />

            <!-- Nút dành riêng cho BIDDER -->
            <Button fx:id="btnBidderItems" text="🏆  Sản Phẩm Đã Thắng"
                    maxWidth="Infinity" onAction="#handleBidderItems"
                    styleClass="button, btn-primary" visible="false" managed="false" />

            <Label text="NGƯỜI BÁN" style="-fx-text-fill: #475569; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 8 0 4 5;"/>

            <Button fx:id="btnCreateItem"    text="➕  Thêm Sản Phẩm"
                    maxWidth="Infinity" styleClass="button, btn-primary" />
            <Button fx:id="btnCreateAuction" text="📊  Tạo Phiên Mới"
                    maxWidth="Infinity" styleClass="button, btn-primary" />

            <Button fx:id="btnSellerDashboard" text="🗂  Sản Phẩm Của Tôi"
                    maxWidth="Infinity" onAction="#handleSellerDashboard"
                    styleClass="button, btn-primary" visible="false" managed="false" />

            <Button fx:id="adminBtn" text="🛡  Quản Trị Viên"
                    maxWidth="Infinity" styleClass="button, btn-warning"
                    visible="false" managed="false" onAction="#handleAdminPanel" />

            <Region VBox.vgrow="ALWAYS" />

            <Button fx:id="btnAccount"       text="👤  Tài Khoản"
                    maxWidth="Infinity" styleClass="button, btn-primary" />
            <!-- Đăng nhập (khi chưa login) -->
            <Button fx:id="btnLogin"         text="🔑  Đăng Nhập"
                    maxWidth="Infinity"
                    style="-fx-background-color: #4F46E5; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 10 20; -fx-font-weight: bold;"
                    visible="false" managed="false" onAction="#handleLogin" />
            <Button fx:id="btnLogout"        text="🚪  Đăng Xuất"
                    maxWidth="Infinity" style="-fx-background-color: transparent; -fx-border-color: #EF4444; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-text-fill: #EF4444; -fx-cursor: hand; -fx-padding: 10 20; -fx-font-weight: bold;" />
        </VBox>
    </left>
    <center>
    </center>

</BorderPane>