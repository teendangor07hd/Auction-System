<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bidhub.client.controller.SellerDashboardController"
      stylesheets="@/css/styles.css"
      styleClass="root"
      spacing="0">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="14"
          style="-fx-padding: 16 20; -fx-background-color: #161B22; -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 0 0 1 0;">
        <Label text="🗂" style="-fx-font-size: 22px;"/>
        <VBox spacing="2">
            <Label text="Sản Phẩm Của Tôi"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: 900;"/>
            <Label text="Quản lý sản phẩm và phiên đấu giá bạn đã tạo"
                   style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <ProgressIndicator fx:id="loadingSpinner" visible="false" prefWidth="24" prefHeight="24"/>
        <Button fx:id="btnRefresh" text="⟳ Làm mới" onAction="#handleRefresh"
                style="-fx-background-color: #2B3139; -fx-text-fill: #E2E8F0; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 16; -fx-border-color: #475569; -fx-border-radius: 8;"/>
    </HBox>

    <!-- Hai cột song song: Sản phẩm | Phiên đấu giá -->
    <HBox spacing="0" VBox.vgrow="ALWAYS">

        <!-- ===== CỘT TRÁI: Sản phẩm đã tạo ===== -->
        <VBox spacing="0" HBox.hgrow="ALWAYS"
              style="-fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 1 0 0;">

            <!-- Sub-header -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 12 18; -fx-background-color: #1A1F2E; -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0;">
                <Label text="📦 Sản phẩm của tôi"
                       style="-fx-text-fill: #E2E8F0; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Label fx:id="lblItemCount" text="(0)"
                       style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="➕ Tạo sản phẩm" onAction="#handleCreateItem"
                        style="-fx-background-color: #4F46E5; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 6 14; -fx-font-size: 12px;"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: #0B0E11; -fx-background: #0B0E11;">
                <VBox fx:id="itemListContainer" spacing="10"
                      style="-fx-padding: 15; -fx-background-color: #0B0E11;"/>
            </ScrollPane>
        </VBox>

        <!-- ===== CỘT PHẢI: Phiên đấu giá đã tạo ===== -->
        <VBox spacing="0" HBox.hgrow="ALWAYS">

            <!-- Sub-header -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 12 18; -fx-background-color: #1A1F2E; -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0;">
                <Label text="🏛 Phiên đấu giá của tôi"
                       style="-fx-text-fill: #E2E8F0; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Label fx:id="lblAucCount" text="(0)"
                       style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="➕ Tạo phiên" onAction="#handleCreateAuction"
                        style="-fx-background-color: #059669; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 6 14; -fx-font-size: 12px;"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: #0B0E11; -fx-background: #0B0E11;">
                <VBox fx:id="aucListContainer" spacing="10"
                      style="-fx-padding: 15; -fx-background-color: #0B0E11;"/>
            </ScrollPane>
        </VBox>

    </HBox>

    <!-- Edit Dialog (overlay ẩn theo mặc định) -->
    <StackPane fx:id="editOverlay" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.7);">
        <VBox fx:id="editPanel" maxWidth="500" spacing="16"
              style="-fx-background-color: #1E2329; -fx-background-radius: 14; -fx-padding: 28; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 20, 0, 0, 8);">
            <Label fx:id="editTitle" text="Chỉnh sửa sản phẩm"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 900;"/>
            <VBox spacing="8">
                <Label text="Tên sản phẩm" style="-fx-text-fill: #94A3B8; -fx-font-size: 12px;"/>
                <TextField fx:id="editName" styleClass="text-input-field"/>
            </VBox>
            <VBox spacing="8">
                <Label text="Mô tả" style="-fx-text-fill: #94A3B8; -fx-font-size: 12px;"/>
                <TextArea fx:id="editDescription" prefRowCount="3" styleClass="text-input-field" wrapText="true"/>
            </VBox>
            <VBox spacing="8">
                <Label text="Giá khởi điểm dự kiến (VNĐ)" style="-fx-text-fill: #94A3B8; -fx-font-size: 12px;"/>
                <TextField fx:id="editPrice" styleClass="text-input-field"/>
            </VBox>
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="Hủy" onAction="#handleEditCancel"
                        style="-fx-background-color: #2B3139; -fx-text-fill: #B7BDC6; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 24;"/>
                <Button fx:id="btnEditSave" text="💾 Lưu thay đổi" onAction="#handleEditSave"
                        style="-fx-background-color: #4F46E5; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 24; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </StackPane>

</VBox>
