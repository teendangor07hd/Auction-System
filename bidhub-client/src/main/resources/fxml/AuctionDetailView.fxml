<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.image.ImageView?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bidhub.client.controller.AuctionDetailController"
      stylesheets="@/css/styles.css"
      styleClass="root"
      spacing="0">

    <HBox alignment="CENTER_LEFT" styleClass="header-bar">
        <Label fx:id="lblTitle" text="Đang tải..." styleClass="header-title"/>
    </HBox>

    <Label fx:id="lblItemName" text="—"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 14 20 0 20;"/>

    <VBox styleClass="content-pane" spacing="12" VBox.vgrow="ALWAYS">

        <!-- Thông tin sản phẩm -->
        <HBox spacing="20" alignment="CENTER_LEFT">
            <StackPane style="-fx-background-color: #2B3139; -fx-background-radius: 12;"
                       prefWidth="170" prefHeight="120">
                <ImageView fx:id="imgProduct" fitWidth="170" fitHeight="120" preserveRatio="true"/>
            </StackPane>
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label fx:id="lblDescription" text="—" wrapText="true"
                       style="-fx-text-fill: #94A3B8;"/>
                <HBox spacing="22">
                    <VBox spacing="3">
                        <Label text="Trạng thái"
                               style="-fx-text-fill: #64748B; -fx-font-size: 11px;"/>
                        <Label fx:id="lblStatus" text="—" styleClass="status-label"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="Giá khởi điểm"
                               style="-fx-text-fill: #64748B; -fx-font-size: 11px;"/>
                        <Label fx:id="lblStartingPrice" text="—"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="Giá hiện tại"
                               style="-fx-text-fill: #64748B; -fx-font-size: 11px;"/>
                        <Label fx:id="lblCurrentPrice" text="—"
                               style="-fx-font-weight: 900; -fx-font-size: 18px; -fx-text-fill: #4F46E5;"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="Người dẫn đầu"
                               style="-fx-text-fill: #64748B; -fx-font-size: 11px;"/>
                        <Label fx:id="lblHighestBidder" text="—"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="Còn lại"
                               style="-fx-text-fill: #64748B; -fx-font-size: 11px;"/>
                        <Label fx:id="lblCountdown" text="—"
                               style="-fx-text-fill: #F59E0B; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>
            </VBox>
        </HBox>

        <Separator style="-fx-opacity: 0.2;"/>

        <!-- Chart + Leaderboard — chiếm hết khoảng trắng còn lại -->
        <HBox spacing="15" VBox.vgrow="ALWAYS">

            <!--
                Chart frame: cố định, không scroll, không zoom.
                LineChart fill toàn bộ frame nhờ fitToWidth/fitToHeight=true.
            -->
            <ScrollPane fx:id="chartScrollPane"
                        fitToWidth="true"
                        fitToHeight="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="NEVER"
                        pannable="false"
                        focusTraversable="false"
                        HBox.hgrow="ALWAYS"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;
                               -fx-border-color: rgba(255,255,255,0.07); -fx-border-radius: 10;">
                <LineChart fx:id="bidChart"
                           title="Lịch sử giá đấu giá"
                           legendVisible="true"
                           createSymbols="true"
                           animated="false">
                    <xAxis>
                        <CategoryAxis fx:id="xAxis" label="Thời gian"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis fx:id="yAxis" label="Giá (VNĐ)" autoRanging="true"/>
                    </yAxis>
                </LineChart>
            </ScrollPane>

            <!-- Leaderboard: cố định 275px -->
            <VBox spacing="8" minWidth="275" maxWidth="275" prefWidth="275">
                <Label text="🏆 Bảng xếp hạng"
                       style="-fx-font-size: 14px; -fx-font-weight: 900; -fx-text-fill: #F59E0B;"/>
                <TableView fx:id="bidTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #1E2329; -fx-border-color: #2B3139;
                                  -fx-background-radius: 8;">
                    <columns>
                        <TableColumn fx:id="colBidderName" text="Người đặt" prefWidth="148"/>
                        <TableColumn fx:id="colBidAmount"  text="Giá (VNĐ)" prefWidth="120"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

        </HBox>

        <!-- Đặt giá -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Giá đặt (VNĐ):"
                   style="-fx-text-fill: #B7BDC6; -fx-font-size: 13px;"/>
            <TextField fx:id="tfBidAmount" promptText="Nhập số tiền..." prefWidth="200"
                       styleClass="text-input-field"/>
            <Button fx:id="btnPlaceBid" text="💰  Đặt Giá"
                    styleClass="button, btn-primary"/>
            <ProgressIndicator fx:id="loadingSpinner" visible="false"
                               prefWidth="28" prefHeight="28"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnBack" text="← Quay lại" styleClass="button"/>
        </HBox>

    </VBox>
</VBox>