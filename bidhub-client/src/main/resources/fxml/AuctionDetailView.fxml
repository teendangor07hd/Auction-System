<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.image.ImageView?>
<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bidhub.client.controller.AuctionDetailController"
      stylesheets="@/css/styles.css"
      styleClass="root"
      spacing="0">

    <HBox alignment="CENTER_LEFT" styleClass="header-bar">
        <Label fx:id="lblTitle" text="Đang tải..." styleClass="header-title"/>
    </HBox>

    <Label fx:id="lblItemName" text="—"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 15 20 0 20;"/>

    <VBox styleClass="content-pane" spacing="15" style="-fx-margin: 0 20 20 20;">

        <HBox spacing="20" alignment="CENTER_LEFT">
            <StackPane style="-fx-background-color: #2B3139; -fx-background-radius: 12;" prefWidth="200" prefHeight="150">
                <ImageView fx:id="imgProduct" fitWidth="200" fitHeight="150" preserveRatio="true" 
                           style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>
            </StackPane>
            <VBox spacing="15">
                <Label fx:id="lblDescription" text="—" wrapText="true"/>
                <HBox spacing="30">
                    <VBox spacing="5">
                        <Label text="Trạng thái:" styleClass="form-label"/>
                        <Label fx:id="lblStatus" text="—" styleClass="status-label"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="Giá khởi điểm:" styleClass="form-label"/>
                        <Label fx:id="lblStartingPrice" text="—"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="Giá hiện tại:" styleClass="form-label"/>
                        <Label fx:id="lblCurrentPrice" text="—"
                               style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #4F46E5;"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="Người dẫn đầu:" styleClass="form-label"/>
                        <Label fx:id="lblHighestBidder" text="—"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="Còn lại:" styleClass="form-label"/>
                        <Label fx:id="lblCountdown" text="—"/>
                    </VBox>
                </HBox>
            </VBox>
        </HBox>

        <Separator/>

        <!-- Chart + Leaderboard: chart bên trái, leaderboard bên phải với kích thước cố định -->
        <HBox spacing="15" VBox.vgrow="ALWAYS">
            <!-- Chart wrapper: fitToWidth, zoom chỉ thay đổi prefHeight không tràn sang leaderboard -->
            <VBox HBox.hgrow="ALWAYS" spacing="5">
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Label text="Phóng to/thu nhỏ đồ thị:" style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;"/>
                    <Button fx:id="btnZoomIn" text="  ➕  " onAction="#handleZoomIn"
                            style="-fx-background-color: #2B3139; -fx-text-fill: #E2E8F0; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 13px; -fx-padding: 4 10; -fx-border-color: #475569; -fx-border-radius: 6;"/>
                    <Button fx:id="btnZoomOut" text="  ➖  " onAction="#handleZoomOut"
                            style="-fx-background-color: #2B3139; -fx-text-fill: #E2E8F0; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 13px; -fx-padding: 4 10; -fx-border-color: #475569; -fx-border-radius: 6;"/>
                    <Button fx:id="btnZoomReset" text="  ↺ Đặt lại  " onAction="#handleZoomReset"
                            style="-fx-background-color: #2B3139; -fx-text-fill: #E2E8F0; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 11px; -fx-padding: 4 10; -fx-border-color: #475569; -fx-border-radius: 6;"/>
                </HBox>
                <ScrollPane fx:id="chartScrollPane" fitToWidth="true" pannable="true"
                            vbarPolicy="AS_NEEDED" hbarPolicy="AS_NEEDED"
                            style="-fx-background-color: transparent; -fx-background: transparent;"
                            prefHeight="320">
                    <LineChart fx:id="bidChart" title="Lịch sử giá đấu giá" legendVisible="true"
                               createSymbols="true" prefHeight="290.0" prefWidth="500.0" minWidth="400.0">
                        <xAxis>
                            <CategoryAxis label="Thời gian" fx:id="xAxis"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Giá (VNĐ)" fx:id="yAxis" autoRanging="true"/>
                        </yAxis>
                    </LineChart>
                </ScrollPane>
            </VBox>

            <!-- Leaderboard bên phải, kích thước cố định không bị chart đẩy -->
            <VBox spacing="10" minWidth="230" maxWidth="260" prefWidth="240">
                <Label text="🏆 Bảng xếp hạng" style="-fx-font-size: 15px; -fx-font-weight: 900; -fx-text-fill: #F59E0B;"/>
                <TableView fx:id="bidTable" VBox.vgrow="ALWAYS" style="-fx-background-color: #1E2329; -fx-border-color: #2B3139;">
                    <columns>
                        <TableColumn fx:id="colBidderName" text="Người đặt" prefWidth="120" />
                        <TableColumn fx:id="colBidAmount" text="Giá (VNĐ)" prefWidth="110" />
                    </columns>
                </TableView>
            </VBox>
        </HBox>

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Giá đặt (VNĐ):" styleClass="form-label"/>
            <TextField fx:id="tfBidAmount" promptText="Nhập số tiền..." prefWidth="200"
                       styleClass="text-input-field"/>
            <Button fx:id="btnPlaceBid" text="Đặt giá"
                    styleClass="button, btn-primary"/>

            <ProgressIndicator fx:id="loadingSpinner" visible="false" prefWidth="30" prefHeight="30" />

            <Button fx:id="btnBack" text="Quay lại"
                    styleClass="button"/>
        </HBox>

    </VBox>
</VBox>