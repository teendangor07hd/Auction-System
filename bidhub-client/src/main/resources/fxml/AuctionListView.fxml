<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bidhub.client.controller.AuctionListController"
      stylesheets="@/css/styles.css"
      styleClass="root"
      spacing="20" style="-fx-padding: 20;">

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Danh sách phiên đấu giá" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS" />

        <ProgressIndicator fx:id="loadingSpinner" visible="false" prefWidth="25" prefHeight="25" />
        <Button fx:id="btnRefresh" text="🔄 Làm mới" styleClass="button" />
    </HBox>

    <StackPane VBox.vgrow="ALWAYS">
        <ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <FlowPane fx:id="cardContainer" hgap="20" vgap="20" alignment="TOP_CENTER" style="-fx-padding: 10;" />
        </ScrollPane>

        <Label fx:id="lblEmptyMessage" text="Không có phiên đấu giá nào"
               visible="false" style="-fx-font-size: 16px; -fx-text-fill: #666;" />
    </StackPane>
</VBox>