<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- Đã sửa: Nạp file styles.css để nhận Modern UI Theme -->
<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bidhub.client.controller.CreateItemController"
      stylesheets="@/css/styles.css"
      styleClass="root" spacing="10" alignment="CENTER"
      prefWidth="550" prefHeight="650">

    <padding><Insets top="20" right="40" bottom="20" left="40"/></padding>

    <!-- Đã sửa: Áp dụng styleClass login-title từ file CSS thay vì hardcode -->
    <Label text="Tạo sản phẩm mới" styleClass="login-title" style="-fx-font-size: 24px;"/>

    <Separator style="-fx-padding: 0 0 10 0;"/>

    <!-- Thêm styleClass text-input-field cho các trường nhập liệu -->
    <TextField fx:id="nameField" promptText="Tên sản phẩm" styleClass="text-input-field"/>
    <TextArea fx:id="descriptionArea" promptText="Mô tả sản phẩm" prefRowCount="3" styleClass="text-input-field"/>
    <TextField fx:id="startingPriceField" promptText="Giá khởi điểm (VND)" styleClass="text-input-field"/>
    <ComboBox fx:id="itemTypeComboBox" promptText="Chọn loại sản phẩm" maxWidth="Infinity" styleClass="text-input-field"/>

    <!-- Dynamic fields: Electronics -->
    <VBox fx:id="electronicsFields" spacing="8">
        <TextField fx:id="brandField" promptText="Thương hiệu (brand)" styleClass="text-input-field"/>
        <TextField fx:id="warrantyMonthsField" promptText="Số tháng bảo hành" styleClass="text-input-field"/>
    </VBox>

    <!-- Dynamic fields: Art -->
    <VBox fx:id="artFields" spacing="8">
        <TextField fx:id="artistField" promptText="Nghệ sĩ (artist)" styleClass="text-input-field"/>
        <TextField fx:id="yearCreatedField" promptText="Năm sáng tác" styleClass="text-input-field"/>
    </VBox>

    <!-- Dynamic fields: Vehicle -->
    <VBox fx:id="vehicleFields" spacing="8">
        <TextField fx:id="manufacturerField" promptText="Nhà sản xuất" styleClass="text-input-field"/>
        <TextField fx:id="yearField" promptText="Năm sản xuất" styleClass="text-input-field"/>
        <TextField fx:id="mileageKmField" promptText="Số km đã đi" styleClass="text-input-field"/>
    </VBox>

    <!-- Đã sửa: Thêm managed="false" để thu hồi không gian khi tàng hình -->
    <Label fx:id="lblMessage" visible="false" managed="false" styleClass="error-message"/>

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 15 0 0 0;">
        <Button text="Hủy" onAction="#handleCancel" styleClass="button, btn-danger-outline"/>
        <Button text="Tạo sản phẩm" onAction="#handleSubmit" styleClass="button, btn-primary"/>
    </HBox>
</VBox>