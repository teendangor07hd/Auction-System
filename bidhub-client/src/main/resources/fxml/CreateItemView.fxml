<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" prefHeight="700.0" prefWidth="600.0" spacing="20.0" styleClass="root" stylesheets="@/css/styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidhub.client.controller.CreateItemController">

    <padding>
        <Insets bottom="30.0" left="50.0" right="50.0" top="30.0" />
    </padding>

    <VBox alignment="CENTER" spacing="5.0">
        <Label style="-fx-font-size: 28px; -fx-text-fill: #2c3e50;" styleClass="login-title" text="THÔNG TIN SẢN PHẨM">
            <VBox.margin>
                <Insets />
            </VBox.margin></Label>
        <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;" text="Vui lòng điền đầy đủ thông tin sản phẩm bên dưới" />
        <Label fx:id="lblMessage" managed="false" styleClass="error-message" visible="false" />
    </VBox>

    <Separator />

    <GridPane hgap="15.0" vgap="18.0">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="120.0" prefWidth="140.0" />
            <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
        </columnConstraints>

        <children>
            <Label text="Tên sản phẩm:" GridPane.rowIndex="0" />
            <TextField fx:id="nameField" promptText="VD: iPhone 15 Pro Max" styleClass="text-input-field" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Mô tả chi tiết:" GridPane.rowIndex="1" GridPane.valignment="TOP" />
            <TextArea fx:id="descriptionArea" prefRowCount="3" promptText="Tình trạng, ngoại hình, phụ kiện đi kèm..." styleClass="text-input-field" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Giá khởi điểm:" GridPane.rowIndex="2" />
            <TextField fx:id="startingPriceField" promptText="Nhập số tiền (VND)" styleClass="text-input-field" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label text="Loại sản phẩm:" GridPane.rowIndex="3" />
            <ComboBox fx:id="itemTypeComboBox" maxWidth="Infinity" promptText="-- Chọn danh mục --" styleClass="text-input-field" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        </children>
        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>
    </GridPane>

    <VBox spacing="15.0">
        <VBox fx:id="electronicsFields" managed="false" spacing="15.0" style="-fx-background-color: #f1f3f5; -fx-padding: 15; -fx-background-radius: 10;" visible="false">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #4361ee;" text="Thông tin Điện tử" />
            <GridPane hgap="15.0" vgap="10.0">
                <columnConstraints>
                    <ColumnConstraints minWidth="120.0" prefWidth="125.0" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>
                <Label text="Thương hiệu:" />
                <TextField fx:id="brandField" styleClass="text-input-field" GridPane.columnIndex="1" />
                <Label text="Bảo hành (tháng):" GridPane.rowIndex="1" />
                <TextField fx:id="warrantyMonthsField" styleClass="text-input-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <rowConstraints>
                    <RowConstraints />
                    <RowConstraints />
                </rowConstraints>
            </GridPane>
        </VBox>

        <VBox fx:id="artFields" managed="false" spacing="15.0" style="-fx-background-color: #fff9db; -fx-padding: 15; -fx-background-radius: 10;" visible="false">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #f08c00;" text="Thông tin Nghệ thuật" />
            <GridPane hgap="15.0" vgap="10.0">
                <columnConstraints>
                    <ColumnConstraints minWidth="120.0" prefWidth="125.0" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>
                <Label text="Nghệ sĩ:" />
                <TextField fx:id="artistField" styleClass="text-input-field" GridPane.columnIndex="1" />
                <Label text="Năm sáng tác:" GridPane.rowIndex="1" />
                <TextField fx:id="yearCreatedField" styleClass="text-input-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <rowConstraints>
                    <RowConstraints />
                    <RowConstraints />
                </rowConstraints>
            </GridPane>
        </VBox>

        <VBox fx:id="vehicleFields" managed="false" spacing="15.0" style="-fx-background-color: #e7f5ff; -fx-padding: 15; -fx-background-radius: 10;" visible="false">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #1971c2;" text="Thông tin Phương tiện" />
            <GridPane hgap="15.0" vgap="10.0">
                <columnConstraints>
                    <ColumnConstraints minWidth="120.0" prefWidth="125.0" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>
                <Label text="Hãng xe:" />
                <TextField fx:id="manufacturerField" styleClass="text-input-field" GridPane.columnIndex="1" />
                <Label text="Năm sản xuất:" GridPane.rowIndex="1" />
                <TextField fx:id="yearField" styleClass="text-input-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <Label text="Số KM đã đi:" GridPane.rowIndex="2" />
                <TextField fx:id="mileageKmField" styleClass="text-input-field" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <rowConstraints>
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                </rowConstraints>
            </GridPane>
        </VBox>
    </VBox>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <ProgressIndicator fx:id="loadingSpinner" visible="false" prefWidth="25" prefHeight="25" />
        <Button fx:id="btnCancel" onAction="#handleCancel" text="Hủy bỏ">
            <styleClass>
                <String fx:value="button" />
                <String fx:value="btn-danger-outline" />
            </styleClass>
        </Button>
        <Button fx:id="btnSubmit" onAction="#handleSubmit" prefWidth="150.0" text="Đăng sản phẩm">
            <styleClass>
                <String fx:value="button" />
                <String fx:value="btn-primary" />
            </styleClass>
        </Button>
    </HBox>
</VBox>