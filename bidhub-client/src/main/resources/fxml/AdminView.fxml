<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.cell.*?>

<!-- [B76] Thêm stylesheets attribute — trước đây thiếu nên CSS không load -->
<!-- [B77] Đổi xmlns version từ 21 về 17 để nhất quán với các FXML khác -->
<!-- [B75] Dùng CSS classes đã được định nghĩa trong styles.css -->
<!-- [B42/GAP1] Thêm nút "Kiểm tra toàn vẹn" để gọi RUN_INTEGRITY_CHECK API -->
<VBox xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bidhub.client.controller.AdminController"
      stylesheets="@../css/styles.css"
      spacing="15" styleClass="container" prefWidth="900" prefHeight="650">

    <!-- [B75] Dùng .header và .title-label — đã được thêm vào styles.css -->
    <HBox styleClass="header" alignment="CENTER_LEFT" spacing="15">
        <Label text="Admin Panel — Quản lý người dùng" styleClass="title-label" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="← Quay lại" onAction="#handleBack" styleClass="btn-secondary" />
    </HBox>

    <!-- Action buttons row -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <!-- Lock/Unlock buttons -->
        <Button text="🔒 Khóa tài khoản" fx:id="lockBtn" disable="true"
                styleClass="btn-danger" onAction="#handleLockUser" />
        <Button text="🔓 Mở khóa" fx:id="unlockBtn" disable="true"
                styleClass="btn-success" onAction="#handleUnlockUser" />
        <Button text="🔄 Làm mới" onAction="#handleRefresh"
                styleClass="btn-secondary" />

        <Region HBox.hgrow="ALWAYS" />

        <!-- [B42/GAP1] Nút RUN_INTEGRITY_CHECK — trước đây là dead code, giờ kích hoạt -->
        <Button text="🛡️ Kiểm tra toàn vẹn" onAction="#handleRunIntegrityCheck"
                styleClass="btn-warning" />
    </HBox>

    <!-- [B78] Đã xóa duplicate column (colAuctionItemName + colAuctionItem) -->
    <TableView fx:id="userTable" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colUsername" text="Tên đăng nhập" prefWidth="180" />
            <TableColumn fx:id="colEmail" text="Email" prefWidth="250" />
            <TableColumn fx:id="colRole" text="Vai trò" prefWidth="120" />
            <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="120" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <!-- [B75] Dùng .status-label — đã được thêm vào styles.css -->
    <Label fx:id="statusLabel" styleClass="status-label" text="Sẵn sàng." />

</VBox>